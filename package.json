{
  "name": "pebble-mineclock",
  "version": "1.3.0",
  "author": "The Minecraft clock",
  "private": true,
  "dependencies": {},
  "keywords": [
    "pebble-app"
  ],
  "scripts": {
    "start": "npm run build && npm run basalt",
    "build": "pebble build",
    "clean": "pebble clean",
    "aplite": "unset PEBBLE_PHONE; pebble install -vvvv --emulator aplite --logs",
    "basalt": "unset PEBBLE_PHONE; pebble install -vvvv --emulator basalt --logs",
    "chalk": "unset PEBBLE_PHONE; pebble install -vvvv --emulator chalk --logs",
    "diorite": "unset PEBBLE_PHONE; pebble install -vvvv --emulator diorite --logs",
    "emery": "unset PEBBLE_PHONE; pebble install -vvvv --emulator emery --logs",
    "flint": "unset PEBBLE_PHONE; pebble install -vvvv --emulator flint --logs",
    "gabbro": "unset PEBBLE_PHONE; pebble install -vvvv --emulator gabbro --logs",
    "iphone": "pebble install --phone $PEBBLE_IPHONE",
    "android": "pebble install --phone $PEBBLE_ANDROID"
  },
  "pebble": {
    "sdkVersion": "3",
    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "bitmap",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu_icon.png"
        },
        {
          "characterRegex": "[0-9:APM ]",
          "type": "font",
          "name": "FONT_MINECRAFTER_25",
          "file": "fonts/minecrafter_3.ttf"
        },
        {
          "characterRegex": "[0-9:APM ]",
          "type": "font",
          "name": "FONT_MINECRAFTER_18",
          "file": "fonts/minecrafter_3.ttf"
        },
        {
          "characterRegex": "[0-9:A-Za-z ]",
          "type": "font",
          "name": "FONT_WHITERABBIT_12",
          "file": "fonts/whiterabbit.ttf"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BOARD",
          "file": "images/board.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BEZEL",
          "file": "images/bezel.png"
        }
      ]
    },
    "projectType": "native",
    "uuid": "a107697e-f275-4428-84d1-9bb92ed0687d",
    "messageKeys": {},
    "enableMultiJS": false,
    "displayName": "Mineclock",
    "watchapp": {
      "onlyShownOnCommunication": false,
      "hiddenApp": false,
      "watchface": true
    },
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "capabilities": []
  }
}
